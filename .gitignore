# ───── secrets / credentials (NEVER commit) ─────
.env
**/.env
settings.json
**/settings.json
instance.json
**/instance.json
active_profile.json
**/active_profile.json
# Real dispatcher profiles hold phone numbers; commit only the .example template.
profiles/profiles.json
**/profiles/profiles.json
# Dispatcher avatar images (binaries) — keep the folder's README, not the images.
profiles/images/*.png
profiles/images/*.jpg
profiles/images/*.jpeg
profiles/images/*.webp
profiles/images/*.gif
**/profiles/images/*.png
**/profiles/images/*.jpg

# ───── customer data: input sheets + staged output (PII) ─────
*.xlsx
*.xls
output/
**/output/
*.pdf
# Extensionless customer spreadsheet that slipped past *.xlsx once — keep it out.
shipment-creator/238EF110

# ───── python ─────
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/

# ───── PyInstaller / build artifacts (regenerated by build.bat) ─────
build/
**/build/
dist/
**/dist/

# ───── runtime / local ─────
*.log
.auth/
**/.auth/
.claude/launch.json
