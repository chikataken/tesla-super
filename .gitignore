# ───── secrets / credentials (NEVER commit) ─────
# Google OAuth client + minted tokens (Gmail API)
secrets/gmail_credentials.json
secrets/gmail_token.json
secrets/didi_gmail_token.json
# IMAP mailbox credentials (didi@tfitrans.com on iPage)
secrets/didi_imap.json
.env
**/.env
settings.json
**/settings.json
instance.json
**/instance.json
# Which dispatcher is currently selected — runtime state, not shared config.
active_profile.json
**/active_profile.json

# ───── local shipment-recorder mirror DB (runtime data, not shared) ─────
**/data/recorder.db
**/data/recorder.db-*

# ───── local Tesla load-tender mirror DB (raw tender emails incl. gate codes) ─────
**/tenders.db
**/tenders.db-*
posting_audit.db
**/posting_audit.db

# ───── SQLite WAL / shared-memory sidecars — transient, regenerated at runtime ─────
*.db-shm
*.db-wal
**/*.db-shm
**/*.db-wal

# ───── customer data: input sheets + staged output (PII) ─────
*.xlsx
*.xls
output/
**/output/
*.pdf
# Extensionless customer spreadsheet that slipped past *.xlsx once — keep it out.
shipment-creator/238EF110

# ───── python ─────
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/

# ───── PyInstaller scratch (regenerated by build.bat) ─────
# Note: dist/ (the shipped app) IS tracked on purpose; only build/ scratch is ignored.
build/
**/build/

# ───── runtime / local ─────
*.log
.auth/
**/.auth/
.claude/launch.json
**/.claude/launch.json

# stray Chrome profile from a misconfigured CDP_PROFILE_DIR (literal Windows path on
# Linux). The dir name has a real backslash, which gitignore treats as an escape —
# so it must be doubled (\\) to match literally.
**/C:\\tesla-profile/

# ───── more local / generated artifacts ─────
# .venv as a symlink (e.g. the test site links to the prod venv) — the trailing-slash
# rules above only match real directories, so catch the bare name too.
.venv
**/.venv
# SuperDispatch vehicle photos scraped by sd_photos.py — customer data, like output/.
sd_photos/
**/sd_photos/
# local DB backups + the promote-to-prod safety snapshot (old code already in git history)
*.db.bak.*
**/*.db.bak.*
.promote-backup-*/
**/.promote-backup-*/

# ───── business-data DBs: keep OUT of the (public) repo ─────
**/terminals.db
wells-check/data/wells.db

# editor swap/lock files (a nano swap of secrets/.env once slipped into a commit)
*.swp
.*.swp
**/.*.swp
**/bids.db
**/bids.db-*
**/sd_events.db
**/sd_events.db-*
