# Copy to .env and fill in. Never commit real values.

# --- Super Dispatch Shipper API (OAuth 2.0 client credentials) ---
# Get these from your Super Dispatch account. Used for order lookup/consolidation
# and order creation.
SUPERDISPATCH_CLIENT_ID=
SUPERDISPATCH_CLIENT_SECRET=

# Which API host to use. "test" (default) uses the sandbox base url; "production"
# uses the live one. Credentials above are used for whichever is selected.
SD_ENV=test

# Optional: override the API base url (defaults to https://api.shipper.superdispatch.com)
# SD_API_BASE=

# --- Tesla / browser automation (BOL download) ---
# Window visibility for the auto-launched Chrome: "visible" (default) or "ghost".
WINDOW_MODE=visible
# HEADLESS=false
# CHROME_PATH=
# CDP_PROFILE_DIR=C:\tesla-profile

# --- Pipeline defaults ---
# EXCEL_PATH=
# GROUP_STRATEGY=auto
