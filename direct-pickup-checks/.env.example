# ============================================================================
#  direct-pickup-checks — copy to `.env` in THIS folder and fill in.
#      direct-pickup-checks/.env.example  ->  direct-pickup-checks/.env
#  `.env` is gitignored. Real environment variables override .env, which
#  overrides the shared ../secrets/.env. So your existing SUPERDISPATCH_*
#  credentials in ../secrets/.env are picked up automatically — you only need
#  to set the webhook-specific values below here.
# ============================================================================

# --- Super Dispatch Shipper API (OAuth 2.0 client credentials) --------------
# Already present in ../secrets/.env for shipment-creator; repeated here only if
# you want to override. Leave blank to inherit the shared secrets file.
# SUPERDISPATCH_CLIENT_ID=
# SUPERDISPATCH_CLIENT_SECRET=
# "test" (default) = sandbox host, "production" = live host.
SD_ENV=test
# Optional: override the API base url (defaults to api.shipper.superdispatch.com)
# SD_API_BASE=

# --- Webhook verification ---------------------------------------------------
# Super Dispatch includes a `verification_token` in every webhook payload. Set the
# SAME value here that you registered with the subscription; the listener rejects
# any request whose token doesn't match (constant-time compare). REQUIRED.
SD_WEBHOOK_VERIFICATION_TOKEN=

# --- Listener ---------------------------------------------------------------
# The listener binds to loopback only; the Cloudflare Tunnel forwards to it.
LISTENER_HOST=127.0.0.1
LISTENER_PORT=8077
# Path the webhook POSTs to. The public callback URL is TUNNEL_PUBLIC_URL + this.
WEBHOOK_PATH=/webhooks/superdispatch

# --- Cloudflare Tunnel ------------------------------------------------------
# Your tunnel's public HTTPS origin (no trailing slash), e.g.
#   https://pickups.example.com
# Used by subscribe.py to build the callback URL it registers with Super Dispatch,
# and by run.sh to provision/run the Cloudflare named tunnel automatically.
# Tunnel credentials are NOT stored here — they live in ~/.cloudflared (created by
# `cloudflared tunnel login`/`create`, which run.sh does for you). Never commit them.
TUNNEL_PUBLIC_URL=https://test.wastake.com
# Name of the named tunnel run.sh creates/runs, and the hostname it routes.
TUNNEL_NAME=direct-pickup
TUNNEL_HOSTNAME=test.wastake.com

# --- Storage ----------------------------------------------------------------
# Root for the SQLite DB and downloaded photos. Defaults to ./data next to the code.
DPC_DATA_DIR=
# Poll interval (seconds) the worker waits between empty queue checks.
WORKER_POLL_SECONDS=2.0
# Max times the worker retries a failed queue item before parking it as 'failed'.
WORKER_MAX_ATTEMPTS=5

# --- Logging ----------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# "json" (structured, default — good for journald) or "text" (human dev console).
LOG_FORMAT=json

# --- Playwright / Super Dispatch web app (photo download + tagging) ---------
# The API can't write tags, so the worker drives the SD web app for the photo +
# tag steps. The browser profile is SHARED with tesla-reconcile / shipment-creator,
# so one `python run_login.py` covers all three.
SD_WEB_BASE=https://shipper.superdispatch.com
# "cdp" = attach to the real installed Chrome (Windows default); "launch" =
# Playwright's own persistent context (default on Mac/Linux). On a headless Linux
# server use launch + HEADLESS=true, or run a CDP Chrome under xvfb (see README).
# AUTH_MODE=launch
# HEADLESS=false
# WINDOW_MODE=visible                 # or "ghost" (off-screen real window)
# CDP_URL=http://127.0.0.1:9222       # cdp mode; keep 127.0.0.1, not localhost
# CDP_PROFILE_DIR=C:\tesla-profile    # shared profile dir (one login for all tools)
# CHROME_PATH=                        # only if chrome isn't auto-detected
# USER_DATA_DIR=                      # launch-mode profile dir (default ./.auth)
# BROWSER_CHANNEL=                    # e.g. "chrome" to use installed Chrome in launch mode

# --- OCR (read VINs off the pickup photos) ----------------------------------
# OCR_ENGINE=easyocr                  # or "tesseract" (needs the tesseract binary)
# OCR_GPU=false
# OCR_ROTATIONS=270,90,180            # rotate-and-retry angles for sideways stickers

# --- Tag labels applied to the order ----------------------------------------
TAG_VIN=VIN
TAG_NO_VIN=NO VIN
TAG_BOT=CLAUDE
