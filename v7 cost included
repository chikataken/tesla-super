Attribute VB_Name = "TeslaFormatter"
Option Explicit

' Tender-cost endpoint (see cost-lookup section at the bottom of this module).
Private Const COSTS_URL As String = "https://shipments.wastake.com/api/tenders/costs"

' ============================================================
'  Tesla Export Formatter  (Mac & Windows compatible)
'  - Deletes rows by OriginLocation
'  - Keeps / reorders columns, adds narrow reference columns, adds a blank "rate" column and model column
'  - Sorts by Origin/Destination State & City
'  - Custom column widths (character + exact-pixel), auto-fits the rest
'  - Adds model code after rate: YL=7SAY + 6th character B; otherwise 4th VIN character C=CT, A=CAB, X=X
'  - Adds a "cost" column after model: Tesla's per-VIN payout from the latest
'    emailed load tender, fetched live from shipments.wastake.com (matched on
'    ShipmentNumber + VIN; latest email wins on re-tenders). First run asks once
'    for the API token (stored per-user via SaveSetting; see ResetTenderCostToken).
'    cost shows "$800" (real number - summable/sortable, black text). LIVE:
'    once a rate is typed on the row, the cost CELL highlights red when
'    cost >= rate, plain otherwise (and while rate is empty). No match = blank.
'    Light-red fill from the start = the tender itself says 0.00.
'    Mac needs the one-time helper: copy TFITenderCosts.applescript into
'    ~/Library/Application Scripts/com.microsoft.Excel/
'  - Writes the result to a new "Formatted" sheet
'  Runs on the workbook that is currently active.
' ============================================================

Sub FormatTeslaExport()

    Dim wb As Workbook
    Dim ws As Worksheet
    Dim outSheet As Worksheet
    Dim arr As Variant
    Dim i As Long, k As Long, r As Long, c As Long
    Dim nRows As Long, nCols As Long
    Dim lastRow As Long, lastCol As Long

    ' ---- EDIT HERE: origins to delete (matched against OriginLocation) ----
    Dim dropOrigins As Variant
    dropOrigins = Array( _
        "Tesla Inc Gigafactory Texas", _
        "Fremont Factory")

    ' ---- EDIT HERE: pickup addresses to delete (matched against OriginAddress) ----
    Dim dropOriginAddresses As Variant
    dropOriginAddresses = Array( _
        "40445 Albrae St", _
        "13101 Tesla Rd", _
        "1 Tesla Rd")

    ' ---- EDIT HERE: output columns, in order (rate added automatically) ----
    Dim outNames As Variant
    outNames = Array( _
        "ShipmentNumber", _
        "Vin", _
        "OriginState", "OriginCity", "OriginAddress", "OriginZip", _
        "OriginLocation", "DestinationLocation", "NeedByDate", "OriginContactPhone", "DestinationContactPhone", _
        "DestinationState", "DestinationCity", "DestinationAddress", "DestinationZip")

    ' ---- EDIT HERE: sort priority, top key first (all ascending) ----
    Dim sortKeys As Variant
    sortKeys = Array("OriginState", "OriginCity", "DestinationState", "DestinationCity")

    ' ---- EDIT HERE: fixed widths in CHARACTERS. Pairs of name, width. ----
    Dim fixedWidths As Variant
    fixedWidths = Array( _
        "OriginAddress", 22, _
        "DestinationAddress", 22, _
        "OriginZip", 9, _
        "DestinationZip", 11, _
        "rate", 10, _
        "model", 5, _
        "cost", 7)

    ' ---- EDIT HERE: exact widths in PIXELS. Pairs of name, pixels. ----
    Dim pixelWidths As Variant
    pixelWidths = Array( _
        "OriginLocation", 1, _
        "DestinationLocation", 1, _
        "NeedByDate", 1, _
        "OriginContactPhone", 1, _
        "DestinationContactPhone", 1)

    ' ----------------------------------------------------------------

    Set wb = ActiveWorkbook
    If wb Is Nothing Then Exit Sub

    On Error Resume Next
    Set ws = wb.Worksheets("VINs")
    On Error GoTo 0
    If ws Is Nothing Then Set ws = wb.ActiveSheet

    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    Application.EnableEvents = False

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    If lastRow < 2 Then
        RestoreApp
        MsgBox "No data rows found on sheet '" & ws.Name & "'.", vbExclamation, "Tesla Formatter"
        Exit Sub
    End If
    arr = ws.Range(ws.Cells(1, 1), ws.Cells(lastRow, lastCol)).Value
    nRows = UBound(arr, 1)
    nCols = UBound(arr, 2)

    Dim srcCol() As Long
    ReDim srcCol(LBound(outNames) To UBound(outNames))
    Dim missing As String
    For k = LBound(outNames) To UBound(outNames)
        srcCol(k) = ColIdx(arr, CStr(outNames(k)))
        If srcCol(k) = 0 Then missing = missing & vbCrLf & "  - " & outNames(k)
    Next k

    Dim olCol As Long
    olCol = ColIdx(arr, "OriginLocation")
    If olCol = 0 Then missing = missing & vbCrLf & "  - OriginLocation (needed to filter rows)"

    Dim oaCol As Long
    oaCol = ColIdx(arr, "OriginAddress")
    If oaCol = 0 Then missing = missing & vbCrLf & "  - OriginAddress (needed to filter rows)"

    If Len(missing) > 0 Then
        RestoreApp
        MsgBox "Can't run. These expected columns weren't found:" & missing, vbExclamation, "Tesla Formatter"
        Exit Sub
    End If

    Dim keep() As Boolean
    ReDim keep(2 To nRows)
    Dim keptCount As Long
    Dim ov As String, oa As String, dropIt As Boolean
    For i = 2 To nRows
        ov = CStr(arr(i, olCol))
        oa = Trim$(CStr(arr(i, oaCol)))
        dropIt = False
        For k = LBound(dropOrigins) To UBound(dropOrigins)
            If ov = CStr(dropOrigins(k)) Then dropIt = True: Exit For
        Next k
        If Not dropIt Then
            For k = LBound(dropOriginAddresses) To UBound(dropOriginAddresses)
                If StrComp(oa, Trim$(CStr(dropOriginAddresses(k))), vbTextCompare) = 0 Then dropIt = True: Exit For
            Next k
        End If
        If Not dropIt Then keep(i) = True: keptCount = keptCount + 1
    Next i

    Dim outCols As Long
    outCols = (UBound(outNames) - LBound(outNames) + 1) + 3

    Dim rateCol As Long
    Dim modelCol As Long
    Dim costCol As Long
    rateCol = outCols - 2
    modelCol = outCols - 1
    costCol = outCols

    Dim vinSrcCol As Long
    vinSrcCol = ColIdx(arr, "Vin")

    Dim outArr() As Variant
    ReDim outArr(1 To keptCount + 1, 1 To outCols)

    For k = LBound(outNames) To UBound(outNames)
        outArr(1, k - LBound(outNames) + 1) = outNames(k)
    Next k
    outArr(1, rateCol) = "rate"
    outArr(1, modelCol) = "model"
    outArr(1, costCol) = "cost"

    Dim vinText As String
    Dim vinCode As String

    r = 1
    For i = 2 To nRows
        If keep(i) Then
            r = r + 1
            For k = LBound(outNames) To UBound(outNames)
                outArr(r, k - LBound(outNames) + 1) = arr(i, srcCol(k))
            Next k

            vinText = CStr(arr(i, vinSrcCol))
            vinCode = ""
            If Len(vinText) >= 6 And _
                    UCase$(Left$(vinText, 4)) = "7SAY" And _
                    UCase$(Mid$(vinText, 6, 1)) = "B" Then
                vinCode = "YL"
            ElseIf Len(vinText) >= 4 Then
                Select Case UCase$(Mid$(vinText, 4, 1))
                    Case "C"
                        vinCode = "CT"
                    Case "A"
                        vinCode = "CAB"
                    Case "X"
                        vinCode = "X"
                End Select
            End If
            outArr(r, modelCol) = vinCode
        End If
    Next i

    ' ---- cost column: per-VIN Tesla payout from the latest emailed tender ----
    Dim costs As Collection
    Dim costStatus As String
    Dim costMatched As Long, costBlank As Long
    Set costs = GetTenderCosts(costStatus)
    If Not costs Is Nothing Then
        Dim shipOutCol As Long, vinOutCol As Long
        shipOutCol = ColIdx(outArr, "ShipmentNumber")
        vinOutCol = ColIdx(outArr, "Vin")
        Dim cKey As String, cVal As String
        For r = 2 To keptCount + 1
            cKey = NormShp(CStr(outArr(r, shipOutCol))) & "|" & UCase$(Trim$(CStr(outArr(r, vinOutCol))))
            cVal = ""
            On Error Resume Next
            cVal = costs(cKey)
            On Error GoTo 0
            If Len(cVal) > 0 Then
                outArr(r, costCol) = Val(cVal)
                costMatched = costMatched + 1
            Else
                costBlank = costBlank + 1
            End If
        Next r
    End If

    On Error Resume Next
    Application.DisplayAlerts = False
    wb.Worksheets("Formatted").Delete
    Application.DisplayAlerts = True
    On Error GoTo 0
    Set outSheet = wb.Worksheets.Add(After:=ws)
    outSheet.Name = "Formatted"

    outSheet.Range(outSheet.Cells(1, 1), outSheet.Cells(keptCount + 1, outCols)).Value = outArr

    ' ---- header row: pitch-black fill, white bold text ----
    With outSheet.Range(outSheet.Cells(1, 1), outSheet.Cells(1, outCols))
        .Font.Bold = True
        .Interior.Color = RGB(0, 0, 0)      ' pitch black fill
        .Font.Color = RGB(255, 255, 255)    ' white text for contrast
    End With

    ' ---- sort (multi-level, ascending) ----
    If keptCount > 1 Then
        With outSheet.Sort
            .SortFields.Clear
            For k = LBound(sortKeys) To UBound(sortKeys)
                c = ColIdx(outArr, CStr(sortKeys(k)))
                If c > 0 Then .SortFields.Add Key:=outSheet.Range(outSheet.Cells(1, c), outSheet.Cells(keptCount + 1, c)), _
                    SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            Next k
            .SetRange outSheet.Range(outSheet.Cells(1, 1), outSheet.Cells(keptCount + 1, outCols))
            .Header = xlYes
            .MatchCase = False
            .Orientation = xlTopToBottom
            .Apply
        End With
    End If

    ' ---- widths: auto-fit, then character overrides, then exact-pixel overrides ----
    outSheet.Columns.AutoFit
    For k = LBound(fixedWidths) To UBound(fixedWidths) Step 2
        c = ColIdx(outArr, CStr(fixedWidths(k)))
        If c > 0 Then outSheet.Columns(c).ColumnWidth = CDbl(fixedWidths(k + 1))
    Next k
    For k = LBound(pixelWidths) To UBound(pixelWidths) Step 2
        c = ColIdx(outArr, CStr(pixelWidths(k)))
        If c > 0 Then SetColumnPixels outSheet.Columns(c), CDbl(pixelWidths(k + 1))
    Next k

    ' ---- model column: centered; darker highlights for CT and CAB only (YL has no highlight) ----
    With outSheet.Range(outSheet.Cells(1, modelCol), outSheet.Cells(keptCount + 1, modelCol))
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
    End With
    If keptCount > 0 Then
        For r = 2 To keptCount + 1
            Select Case CStr(outSheet.Cells(r, modelCol).Value)
                Case "CT"
                    outSheet.Cells(r, modelCol).Interior.Color = RGB(191, 191, 191)   ' darker gray
                Case "CAB"
                    outSheet.Cells(r, modelCol).Interior.Color = RGB(255, 192, 0)     ' darker gold
                Case "X"
                    ' no highlight
            End Select
        Next r
    End If

    ' ---- cost column ----------------------------------------------------------
    ' The tender's per-VIN payout as a real NUMBER shown "$800" (summable, sorts
    ' numerically, black text). LIVE conditional format: once a rate is typed on
    ' the row the CELL highlights red when cost >= rate, plain otherwise (and
    ' while rate is empty). Static light-red fill = the tender really says 0.00.
    ' No tender match = cell stays blank.
    With outSheet.Range(outSheet.Cells(2, costCol), outSheet.Cells(keptCount + 1, costCol))
        .NumberFormat = "$#,##0"
        .HorizontalAlignment = xlRight
    End With
    If keptCount > 0 Then
        Dim cv As Variant
        For r = 2 To keptCount + 1
            cv = outSheet.Cells(r, costCol).Value
            If IsNumeric(cv) And Len(Trim$(CStr(cv))) > 0 Then
                If CDbl(cv) = 0 Then
                    outSheet.Cells(r, costCol).Interior.Color = RGB(255, 199, 206)  ' 0.00 tender
                End If
            End If
        Next r

        Dim costRng As Range, costFirst As String, rateFirst As String
        Set costRng = outSheet.Range(outSheet.Cells(2, costCol), outSheet.Cells(keptCount + 1, costCol))
        costFirst = costRng.Cells(1, 1).Address(False, False)
        rateFirst = outSheet.Cells(2, rateCol).Address(False, False)
        With costRng.FormatConditions.Add(Type:=xlExpression, Formula1:= _
                "=AND(ISNUMBER(" & costFirst & "),ISNUMBER(" & rateFirst & ")," & _
                costFirst & ">=" & rateFirst & ")")
            .Interior.Color = RGB(255, 0, 0)  ' red cell: cost at or above rate
            .Font.Color = RGB(0, 0, 0)        ' text stays black
        End With
    End If

    ' ---- borders: outline every cell in the data range ----
    With outSheet.Range(outSheet.Cells(1, 1), outSheet.Cells(keptCount + 1, outCols)).Borders
        .LineStyle = xlContinuous
        .Weight = xlThin
        .Color = RGB(0, 0, 0)
    End With

    outSheet.Range("A2").Select
    ActiveWindow.FreezePanes = True

    RestoreApp
    outSheet.Activate

    Dim costLine As String
    If costs Is Nothing Then
        costLine = "Costs:   " & costStatus
    Else
        costLine = "Costs:   " & costMatched & " filled, " & costBlank & " no match"
    End If
    MsgBox "Done." & vbCrLf & _
           "Kept:    " & keptCount & " rows" & vbCrLf & _
           "Removed: " & (nRows - 1 - keptCount) & " rows" & vbCrLf & _
           costLine & vbCrLf & _
           "Result is on the 'Formatted' sheet.", vbInformation, "Tesla Formatter"
End Sub

' Returns the column number whose header matches name (case-insensitive), or 0.
Private Function ColIdx(ByRef arr As Variant, ByVal name As String) As Long
    Dim j As Long
    ColIdx = 0
    For j = 1 To UBound(arr, 2)
        If StrComp(Trim$(CStr(arr(1, j))), name, vbTextCompare) = 0 Then
            ColIdx = j
            Exit Function
        End If
    Next j
End Function

' Sets a column to an exact pixel width by iterating ColumnWidth (96 DPI).
Private Sub SetColumnPixels(ByVal col As Range, ByVal px As Double)
    Dim targetPts As Double, curPts As Double, cw As Double, i As Long
    targetPts = px * 72# / 96#
    col.ColumnWidth = 8.43
    For i = 1 To 25
        curPts = col.Width
        If curPts <= 0 Then Exit Sub
        If Abs(curPts - targetPts) <= 0.25 Then Exit Sub
        cw = col.ColumnWidth * (targetPts / curPts)
        If cw < 0 Then cw = 0
        If cw > 255 Then cw = 255
        col.ColumnWidth = cw
    Next i
End Sub

Private Sub RestoreApp()
    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
End Sub

' ============================================================
'  Tender-cost lookup (fills the "cost" column)
'  Data: GET shipments.wastake.com/api/tenders/costs -> CSV shp,vin,cost
'  (per-VIN payout from the LATEST Tesla tender email per shipment).
'  Token: asked for once per user/machine, kept via SaveSetting.
'  NEVER hardcode the token here - this file lives in a public repo.
' ============================================================

' Returns a Collection keyed "SHPSUFFIX|VIN" -> cost string, or Nothing with
' a human-readable reason in status (macro then leaves the column blank).
Private Function GetTenderCosts(ByRef status As String) As Collection
    Dim tok As String
    tok = GetSetting("TFITrans", "TenderCosts", "Token", "")
    If Len(tok) = 0 Then
        tok = Trim$(InputBox("Paste the tender-cost API token (ask Andrew)." & vbCrLf & _
                             "Cancel = skip the cost column this run.", "TFI Tender Costs"))
        If Len(tok) = 0 Then
            status = "skipped (no token entered)"
            Exit Function
        End If
    End If

    Dim body As String, code As Long
    code = FetchUrl(COSTS_URL & "?token=" & tok, body)
    If code = 401 Then
        On Error Resume Next
        DeleteSetting "TFITrans", "TenderCosts", "Token"
        On Error GoTo 0
        status = "token rejected - run the macro again to re-enter it"
        Exit Function
    ElseIf code <> 200 Then
        status = "lookup unavailable (HTTP " & code & ") - column left blank"
        Exit Function
    End If
    SaveSetting "TFITrans", "TenderCosts", "Token", tok

    Dim out As New Collection
    Dim lines() As String, parts() As String, j As Long
    body = Replace(body, vbCrLf, vbLf)
    lines = Split(body, vbLf)
    For j = 1 To UBound(lines)                       ' line 0 is the header
        parts = Split(lines(j), ",")
        If UBound(parts) >= 2 Then
            On Error Resume Next                     ' duplicate key -> keep first
            out.Add CStr(parts(2)), NormShp(parts(0)) & "|" & UCase$(Trim$(parts(1)))
            On Error GoTo 0
        End If
    Next j
    Set GetTenderCosts = out
    status = ""
End Function

' "SHP2607-A3WW630" and "A3WW630" both -> "A3WW630" (export sometimes omits the
' SHPyymm- prefix; the tender emails always include it).
Private Function NormShp(ByVal s As String) As String
    Dim p As Long
    s = UCase$(Trim$(s))
    If Left$(s, 3) = "SHP" Then
        p = InStr(s, "-")
        If p > 0 Then s = Mid$(s, p + 1)
    End If
    NormShp = s
End Function

' Cross-platform GET. Returns the HTTP status (0 = could not connect).
' Windows: MSXML2 (built in). Mac: AppleScriptTask -> curl; needs
' TFITenderCosts.applescript in ~/Library/Application Scripts/com.microsoft.Excel/
Private Function FetchUrl(ByVal url As String, ByRef body As String) As Long
#If Mac Then
    Dim resp As String, p As Long
    On Error GoTo failed
    resp = AppleScriptTask("TFITenderCosts.applescript", "FetchCosts", url)
    If Len(resp) = 0 Or resp = "CURLERR" Then GoTo failed
    p = InStrRev(resp, vbLf)                         ' curl appends "\n<status>"
    If p = 0 Then GoTo failed
    FetchUrl = Val(Mid$(resp, p + 1))
    body = Left$(resp, p - 1)
    Exit Function
failed:
    FetchUrl = 0
#Else
    Dim http As Object
    On Error GoTo failed
    Set http = CreateObject("MSXML2.ServerXMLHTTP.6.0")
    http.Open "GET", url, False
    http.setTimeouts 5000, 5000, 10000, 15000
    http.Send
    FetchUrl = http.Status
    body = http.responseText
    Exit Function
failed:
    FetchUrl = 0
#End If
End Function

' Run this to force the token prompt on the next FormatTeslaExport run
' (e.g. after the server token is rotated).
Public Sub ResetTenderCostToken()
    On Error Resume Next
    DeleteSetting "TFITrans", "TenderCosts", "Token"
    On Error GoTo 0
    MsgBox "Stored token cleared - the next run will ask for a new one.", _
           vbInformation, "TFI Tender Costs"
End Sub
