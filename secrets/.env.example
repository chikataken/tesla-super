# ============================================================================
#  Shared credentials for BOTH tools (shipment-creator + tesla-reconcile).
#  Copy this file to `.env` in THIS folder and fill in the values.
#      secrets/.env.example   ->   secrets/.env
#  `secrets/.env` is gitignored and is the ONE place keys live. Never commit it.
# ============================================================================

# --- Claude vision API key (console.anthropic.com) -------------------------
# Used by tesla-reconcile to read VIN / delivery photos.
ANTHROPIC_API_KEY=

# --- Super Dispatch Shipper API (OAuth 2.0 client credentials) -------------
# Used by shipment-creator for order lookup / consolidation / creation.
SUPERDISPATCH_CLIENT_ID=
SUPERDISPATCH_CLIENT_SECRET=
# "test" (default) = sandbox host, "production" = live host.
SD_ENV=test
# Optional: override the API base url (defaults to api.shipper.superdispatch.com)
# SD_API_BASE=

# --- Tesla / browser automation (shared Chrome profile) --------------------
# One manual login covers both tools when they share CDP_PROFILE_DIR.
# Window visibility for the auto-launched Chrome: "visible" (default) or "ghost".
WINDOW_MODE=visible
# AUTH_MODE=cdp                      # cdp = attach to real Chrome (Windows default)
# CDP_URL=http://127.0.0.1:9222      # keep 127.0.0.1, not localhost
# CDP_PROFILE_DIR=C:\tesla-profile   # shared profile for both tools
# CHROME_PATH=                       # only if chrome.exe isn't auto-detected
# HEADLESS=false                     # avoid: true headless is what Tesla detects

# --- Tesla Logistics ANDROID APP login (app-delivery / emulator) -----------
# SEPARATE from the Tesla *website* login above. This is the carrier driver app's
# SSO sign-in (auth.tesla.com), which app-delivery uses to auto-recover when the app
# logs itself out after inactivity (it hangs on an infinite spinner; we restart and
# sign back in). The app account can differ from the website account, so it gets its
# own variables. TESLA_APP_TOTP_SECRET is the base32 2FA seed — only if 2FA is on.
TESLA_APP_EMAIL=
TESLA_APP_PASSWORD=
# TESLA_APP_TOTP_SECRET=

# --- Optional pipeline / business rules ------------------------------------
# EXCEL_PATH=
# GROUP_STRATEGY=auto
# PAYMENT_WINDOW_DAYS=7
# LOOKBACK_DAYS=30
# WINDOW_DAYS=14
# ZIP_DRIVE_MINUTES=21
